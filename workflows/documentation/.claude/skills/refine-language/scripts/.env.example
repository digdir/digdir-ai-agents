# Konfigurasjon for Borealis språkforbedring
# Kopier denne filen til .env og tilpass verdiene

# API-endepunkt for LLM-tjenesten, OpenaAI-kompatible, f.eks Ollama eller LMStudio
# Eksempler:
#   Lokal LM Studio: http://localhost:1234/v1/chat/completions
BOREALIS_API_URL=http://localhost:1234/v1/chat/completions

# Modellnavn (avhenger av hva som er tilgjengelig på serveren)
# Eksempler:
#   LM Studio: borealis-4b-instruct-preview
#   Ollama: hf.co/NbAiLab/borealis-4b-instruct-preview-gguf:BF16
BOREALIS_MODEL=hf.co/NbAiLab/borealis-4b-instruct-preview-gguf:BF16
